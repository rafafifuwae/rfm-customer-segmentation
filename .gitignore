# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Jupyter Notebook
.ipynb_checkpoints/

# Environments
.env
.venv
env/
venv/
ENV/

# IDE
.vscode/
.idea/
*.swp
*.swo
.claude/

# Data files (di-track oleh DVC, terlalu besar untuk Git)
data/raw/*.csv
data/interim/*.csv
data/processed/*.csv
!data/raw/.gitkeep
!data/interim/.gitkeep
!data/processed/.gitkeep

# Model & artifacts (umum di-ignore, kecuali model utama untuk deployment)
models/*.pkl
models/*.joblib
!models/.gitkeep
!models/kmeans_rfm.pkl

# Reports — figure modeling & deployment screenshot DI-TRACK untuk
# kebutuhan laporan & portofolio. Hanya ignore artifact temporary.
!reports/figures/*.png
!reports/figures/*.jpg

# OS
.DS_Store
Thumbs.db

# DVC
/data/raw/.gitignore
.dvc/tmp
.dvc/cache
